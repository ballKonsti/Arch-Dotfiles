{
  "name": "Cipher Hybrid",
  "appearance": "dark",
  
  "colors": {
    // ============================================
    // EDITOR CORE - BALANCED TRANSPARENCY
    // ============================================
    "editor.background": "#0a0e15",
    "editor.foreground": "#d4d4d4",
    "editor.gutter.background": "#0a0e15",
    "editor.line_number": "#3e4451",
    "editor.active_line_number": "#6c7086",
    "editor.wrap_guide": "#1a1f2e",
    "editor.active_wrap_guide": "#2d3748",
    "editor.whitespace": "#3e445144",
    
    // ============================================
    // SELECTION & HIGHLIGHTS
    // ============================================
    "editor.selection.background": "#2d1b4e88",
    "editor.selection.foreground": "#e8e8e8",
    "editor.line_highlight": "#1a1f2e44",
    "editor.document_highlight.read_background": "#2d1b4e55",
    "editor.document_highlight.write_background": "#3d2d4d55",
    "editor.find_match_background": "#3d2d4d88",
    "editor.find_match_highlight_background": "#3d2d4d55",
    "editor.find_match_border": "#6b5b95ff",
    
    // ============================================
    // CURSOR & SEARCH
    // ============================================
    "editor.cursor": "#8b7ab8",
    "editor.search.match_background": "#3d2d4d77",
    "editor.search.selected_match_background": "#5d3d6dff",
    "editor.search.match_border": "#7b5b99ff",
    

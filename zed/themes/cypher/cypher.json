    "terminal.ansi.green": "#7eb5a8",
    "terminal.ansi.yellow": "#d4b896",
    "terminal.ansi.blue": "#7b9bc8",
    "terminal.ansi.magenta": "#a885d4",
    "terminal.ansi.cyan": "#7eb5c4",

    // DIAGNOSTICS
    // ============================================
    "diagnostic.error.color": "#ff8899",
    "diagnostic.warning.color": "#d4b896",
    "diagnostic.information.color": "#7b9bc8",
    "diagnostic.hint.color": "#7eb5a8",
    

    // ============================================
    "editorBracketMatch.background": "#3d2d4d88",
    "editorBracketMatch.border": "#8b7ab8ff",
    "editorBracketPairGuide.background1": "#3e445122",
    "editorBracketPairGuide.background2": "#5a5a7a22",
    "editorBracketPairGuide.background3": "#7b5b9522",
    

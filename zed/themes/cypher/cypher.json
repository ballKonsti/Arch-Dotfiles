    "peekViewEditorGutter.background": "#0f131955",
    "peekViewResult.background": "#0a0e1566",
    "peekViewResult.fileForeground": "#d4d4d4",
    "peekViewResult.lineForeground": "#8a9aaa",
    "peekViewResult.matchHighlightBackground": "#3d2d4d88",
    "peekViewResult.selectionBackground": "#3d2d4dff",
    "peekViewResult.selectionForeground": "#e8e8e8",
    

        "font_style": "italic"
      },
      "string": {
        "color": "#7eb5a8"
      },
      "string.escape": {
        "color": "#d4b896"
      },
      "number": {
        "color": "#d4b896"
      },
      "boolean": {
        "color": "#a885d4"
      },
      "keyword": {
        "color": "#8b7ab8",
        "font_style": "bold"
      },
      "operator": {
        "color": "#c4a8d8"
      },
      "function": {
        "color": "#7b9bc8"
      },
      "method": {
        "color": "#7b9bc8"
      },
      "type": {
        "color": "#7eb5c4"
      },
      "variable": {
        "color": "#d4d4d4"
      },
      "property": {
        "color": "#8badde"
      },
      "attribute": {
        "color": "#7eb5a8"
      },
      "tag": {
        "color": "#8b7ab8"
      },
      "tag.name": {
        "color": "#8b7ab8"
      },
      "tag.attribute": {
        "color": "#7b9bc8"
      },
      "tag.delimiter": {
        "color": "#c4a8d8"
      },
      "punctuation": {
        "color": "#8a9aaa"
      },
      "punctuation.bracket": {
        "color": "#c4a8d8"
      },
      "punctuation.delimiter": {
        "color": "#8a9aaa"
      }
    },
    

    "dropdown.foreground": "#d4d4d4",
    "menu.background": "#0f1319bb",
    "menu.border": "#3d2d4dbb",
    "menu.foreground": "#d4d4d4",
    "menu.selectionBackground": "#3d2d4dff",
    "menu.selectionForeground": "#e8e8e8",
    

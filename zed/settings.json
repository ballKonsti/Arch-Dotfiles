{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "language_models": {
    "openai_compatible": {
      "OpenWebUi": {
        "api_url": "https://lsm.feraxhp.com/ollama/v1",
        "available_models": [
          {
            "name": "gemma:7b",
            "max_tokens": 2000000,
            "max_output_tokens": 320000,
            "max_completion_tokens": 2000000,
            "capabilities": {
              "tools": false,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
          {
            "name": "stable-code:3b",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": false,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
          {
            "name": "qwen3-coder:30b",
            "max_tokens": 256000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },

  "colorize_brackets": true,

  "message_editor": {
    "auto_replace_emoji_shortcode": true,
  },

  "base_keymap": "VSCode",

  "title_bar": {
    "show_onboarding_banner": true,
    "show_user_picture": true,
    "show_menus": false,
    "show_branch_icon": true,
  },

  "ui_font_family": ".ZedSans",

  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte - No Italics",
    "dark": "Transparent Prism",
  },

  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Latte",
  },

  "active_pane_modifiers": {
    "border_size": 0.9,
    "inactive_opacity": 1,
  },

  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
  },

  "edit_predictions": {
    "disabled_globs": [],
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
    "ollama": {
      "api_url": "http://home.dk:11434",
      "model": "stable-code:3b",
    },
    "provider": "ollama",
  },

  "agent": {
    "dock": "right",
    "default_view": "text_thread",
    "default_model": {
      "provider": "OpenWebUi",
      "model": "qwen3-coder:30b",
    },
  },

  "languages": {
    "C++": {
      "tab_size": 4,
      "format_on_save": "on",
      "remove_trailing_whitespace_on_save": true,
      "ensure_final_newline_on_save": true,
      "language_servers": ["clangd"],
    },

    "Plain Text": {
      "remove_trailing_whitespace_on_save": true,
      "format_on_save": "off",
      "tab_size": 4,
      "ensure_final_newline_on_save": false,
    },
    "Python": {
      "tab_size": 4,
      "format_on_save": "off",
      "ensure_final_newline_on_save": true,
    },
    "JSONC": {
      "show_edit_predictions": true,
      "tab_size": 2,
    },
    "YAML": {
      "tab_size": 2,
    },
    "JSON": {
      "remove_trailing_whitespace_on_save": false,
      "format_on_save": "off",
      "tab_size": 4,
      "show_edit_predictions": false,
      "ensure_final_newline_on_save": false,
    },
    "Markdown": {
      "show_edit_predictions": false,
      "enable_language_server": true,
    },
    "JavaScript": {
      "tab_size": 2,
    },
    "TypeScript": {
      "tab_size": 2,
    },
    "HTML": {
      "language_servers": ["emmet-language-server"],
    },

    "Blade": {
      "tab_size": 2,
      "soft_wrap": "preferred_line_length",
      "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["<", ">"],
        ["{{", "}}"],
        ["{!!", "!!}"],
        ["@if", "@endif"],
        ["@foreach", "@endforeach"],
        ["@for", "@endfor"],
        ["@while", "@endwhile"],
        ["@section", "@endsection"],
        ["@isset", "@endisset"],
        ["@empty", "@endempty"],
        ["@switch", "@endswitch"],
        ["@push", "@endpush"],
        ["@once", "@endonce"],
        ["@php", "@endphp"],
      ],
    },
  },

  "autosave": "on_focus_change",
  "restore_on_startup": "launchpad",
  "auto_update": true,
  "use_system_prompts": false,

  "ui_font_size": 15,
  "buffer_font_size": 16.0,
  "buffer_font_family": ".ZedSans",

  "buffer_font_fallbacks": [
    ".ZedMono",
    "JetBrains Mono",
    "JetBrainsMono Nerd Font",
    "Cascadia Mono",
  ],

  "confirm_quit": false,
  "load_direnv": "shell_hook",
  "hide_mouse": "on_typing",
  "snippet_sort_order": "bottom",

  "scrollbar": { "show": "never" },

  "minimap": {
    "show": "never",
    "thumb": "hover",
    "thumb_border": "none",
    "current_line_highlight": "none",
  },

  "tab_bar": {
    "show": false,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },

  "tabs": {
    "close_position": "right",
    "file_icons": false,
    "git_status": true,
  },

  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": true,
  },

  "format_on_save": "on",

  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 100,
      "padding": 4,
      "min_column": 40,
      "max_severity": "all",
    },
    "include_warnings": true,
  },

  "git": {
    "git_gutter": "tracked_files",
    "gutter_debounce": 100,
    "inline_blame": {
      "enabled": true,
      "min_column": 40,
      "delay_ms": 0,
      "show_commit_summary": true,
    },
    "hunk_style": "unstaged_hollow",
  },

  "indent_guides": {
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },

  "hard_tabs": false,

  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": null,
  },

  "remove_trailing_whitespace_on_save": false,
  "ensure_final_newline_on_save": false,
  "show_whitespaces": null,
  "soft_wrap": "none",
  "tab_size": 4,

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "terminal": {
    "working_directory": "current_project_directory",
    "keep_selection_on_copy": false,
    "font_family": "JetBrains Mono",
    "env": { "ZED": "1" },
    "font_size": 13,
  },

  "unnecessary_code_fade": 0.8,
}
